# ============================================
# CLAWDRA ENVIRONMENT CONFIGURATION
# ============================================
# Set ONE provider below. Clawdra auto-detects which to use.
# Get your API key from the provider's website.
# Clawdra doesn't handle billing — you pay the provider directly.
# ============================================

# ── AI Provider (pick ONE) ──────────────────

# Ollama (FREE - runs locally, no key needed)
# Download: https://ollama.com
# Then run: ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434

# Anthropic (Claude models)
# Get key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (GPT models)
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# OpenRouter (200+ models from one key, some free)
# Get key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Google Gemini (free tier available)
# Get key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# ── Optional Settings ───────────────────────

# Web search (for /research command)
# EXA_API_KEY=...
# TAVILY_API_KEY=...

# Channels (messaging platforms)
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=...

# Voice
# TTS_PROVIDER=edge-tts
# TTS_VOICE=en-US-AriaNeural

# Logging
# LOG_LEVEL=info
